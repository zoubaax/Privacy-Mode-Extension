{
  "manifest_version": 3,
  "name": "Privacy Mode",
  "version": "1.0",
  "description": "Blurs chat messages and sidebar history on supported chat apps.",
  "permissions": ["storage", "activeTab"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Privacy Mode",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://gemini.google.com/*",
        "*://claude.ai/*",
        "*://perplexity.ai/*",
        "*://*.perplexity.ai/*",
        "*://chat.deepseek.com/*",
        "*://*.deepseek.com/*",
        "*://kimi.moonshot.cn/*",
        "*://*.moonshot.cn/*",
        "*://kimi.com/*",
        "*://*.kimi.com/*",
        "*://qwen.ai/*",
        "*://*.qwen.ai/*",
        "*://web.whatsapp.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
